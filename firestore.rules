rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: kiểm tra user hiện tại có phải superadmin không
    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Helper: kiểm tra user hiện tại có trong collection admins (studio hoặc superadmin)
    function isStudio() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Feedback: Ai cũng có thể tạo, chỉ admin/studio đã xác thực mới đọc/xóa
    match /feedback/{id} {
      allow create: if true;
      allow read, delete: if isStudio();
    }

    // Admins: Studio đọc được record của chính mình; superadmin đọc/ghi tất cả
    // Cho phép write chính mình khi chưa tồn tại (khởi tạo lần đầu)
    match /admins/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin()
        || (request.auth != null && request.auth.uid == uid
            && !exists(/databases/$(database)/documents/admins/$(uid)));
    }

    // Sessions: Guest có sessionId trực tiếp (từ QR) vẫn xem được (get by ID)
    //           Studio chỉ tạo session với studioId = uid của mình
    //           Studio chỉ list/xóa/update session của mình; superadmin xem tất cả
    match /sessions/{id} {
      allow get: if true;
      allow create: if isStudio()
        && request.resource.data.studioId == request.auth.uid;
      allow list, delete, update: if isStudio()
        && (resource.data.studioId == request.auth.uid || isSuperAdmin());
    }

    // Frames: Ai cũng đọc; Studio chỉ ghi đc khung của mình, superadmin ghi tất cả
    match /frames/{id} {
      allow read: if true;
      allow write: if isSuperAdmin() 
        || (isStudio() 
            && request.resource.data.studioId == request.auth.uid 
            && (!exists(resource.path) || resource.data.studioId == request.auth.uid));
    }

    // Frame Requests: Ai cũng tạo; chỉ superadmin quản lý
    match /frame_requests/{id} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }
  }
}
