rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Feedback: Ai cũng có thể tạo, chỉ Admin có thể đọc và xóa
    match /feedback/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // Admins: Chỉ những ai đã là admin (có canManageAdmins) mới có thể đọc/ghi danh sách admin
    // Để khởi tạo super admin ban đầu, cho phép read nếu là chính mình
    match /admins/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions.canManageAdmins == true);
      allow write: if request.auth != null && (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions.canManageAdmins == true || (request.auth.uid == uid && !exists(/databases/$(database)/documents/admins/$(uid))));
    }

    // Sessions: Đọc public theo ID, tạo public, chỉ Admin có thể xóa/list/update
    match /sessions/{id} {
      allow create, get: if true;
      allow list, delete, update: if request.auth != null;
    }

    // Frames: Ai cũng có thể đọc, chỉ Admin có thể viết
    match /frames/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Frame Requests: Ai cũng có thể tạo đề xuất, chỉ Admin có thể quản lý
    match /frame_requests/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
