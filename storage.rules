rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ảnh photobooth & recap — đọc public, viết chỉ auth
    match /photobooth/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /recap/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Frames do admin upload — đọc public, viết chỉ admin
    match /frames/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Frame contributions từ user — đọc chỉ admin, ai cũng tạo được
    match /frame-requests/{file} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Session photos & videos — đọc public, chỉ studio đã xác thực mới upload
    // Path structure: sessions/{sessionId}/... (legacy) or sessions/{studioId}/{sessionId}/...
    match /sessions/{firstSegment}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
